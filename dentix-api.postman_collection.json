{
  "info": {
    "name": "Dentix API",
    "description": "Complete API collection for the Dentix dental SaaS platform (multi-company).\n\n## Setup\n1. Run `php artisan migrate:fresh --seed`\n2. Start the server: `php artisan serve`\n3. Set `base_url` variable (default: `http://localhost:8000`)\n4. First run **Login (Staff)** to auto-save the token\n5. `company_id` is auto-assigned from the authenticated user — no need to send it in requests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "company_id", "value": "1", "type": "string" }
  ],
  "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Staff)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["if (pm.response.code === 200) { var json = pm.response.json(); pm.collectionVariables.set('token', json.token); if (json.user && json.user.company_id) pm.collectionVariables.set('company_id', json.user.company_id); }"],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@dental.com\",\n  \"password\": \"admin123\"\n}" },
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Login (Patient)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"patient@dental.com\",\n  \"password\": \"patient123\"\n}" },
            "url": { "raw": "{{base_url}}/api/auth/login/patient", "host": ["{{base_url}}"], "path": ["api", "auth", "login", "patient"] }
          }
        },
        {
          "name": "Login (Staff route)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@dental.com\",\n  \"password\": \"admin123\"\n}" },
            "url": { "raw": "{{base_url}}/api/auth/login/staff", "host": ["{{base_url}}"], "path": ["api", "auth", "login", "staff"] }
          }
        },
        {
          "name": "My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/me", "host": ["{{base_url}}"], "path": ["api", "auth", "me"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/logout", "host": ["{{base_url}}"], "path": ["api", "auth", "logout"] }
          }
        },
        {
          "name": "Update Photo",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"photo\": \"/images/new-photo.jpg\"\n}" },
            "url": { "raw": "{{base_url}}/api/auth/photo", "host": ["{{base_url}}"], "path": ["api", "auth", "photo"] }
          }
        }
      ]
    },
